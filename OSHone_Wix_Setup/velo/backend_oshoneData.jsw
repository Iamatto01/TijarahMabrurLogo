// });

// Function untuk dapatkan data company user (userId dipass dari frontend/session)
export async function getCurrentUserCompany(userId) {
    try {
        if (!userId) {
            console.error("User ID diperlukan untuk carian company");
            return null;
        }
        
        // Cari company yang owner dia adalah user yang login menggunakan @wix/sdk
        const companyQuery = await wixClient.items.queryDataItems({ dataCollectionId: "Companies" })
            .eq("owner", userId)
            .find();
            
        if (companyQuery.items.length > 0) {
            // Dalam @wix/sdk, data field sebenar ada di dalam property 'data'
            return companyQuery.items[0].data;
        } else {
            return null; // Admin TMSB atau user takde company
        }
    } catch (error) {
        console.error("Error fetching company from CMS:", error);
        throw error;
    }
}

// Function dapatkan statistik Dashboard
export async function getDashboardStats(companyId) {
    if (!companyId) return null;

    const today = new Date();
    const expiryWarningDate = new Date();
    expiryWarningDate.setMonth(today.getMonth() + 3); // 3 bulan amaran

    try {
        // Ambil semua assets untuk company ini
        const assetsQuery = await wixClient.items.queryDataItems({ dataCollectionId: "Assets" })
            .eq("company", companyId)
            .find();
            
        // Map data sebenar
        const assets = assetsQuery.items.map(item => item.data);
        const totalAssets = assets.length;
        
        // Kira CF yang expired / nak expired (merah)
        const alertAssets = assets.filter(asset => {
            const cfDate = new Date(asset.cfExpiryDate);
            return cfDate < expiryWarningDate;
        });
        const alertCount = alertAssets.length;
        
        // Kira Compliance % (Contoh formula simple: Valid CF / Total Mesin)
        const validAssets = assets.filter(asset => {
            const cfDate = new Date(asset.cfExpiryDate);
            return cfDate >= today;
        });
        const validCount = validAssets.length;
            
        const complianceRate = totalAssets > 0 ? Math.round((validCount / totalAssets) * 100) : 0;

        return {
            totalAssets,
            alertCount,
            complianceRate,
            alerts: alertAssets
        };
    } catch (error) {
        console.error("Error fetching dashboard stats from CMS:", error);
        throw error;
    }
}

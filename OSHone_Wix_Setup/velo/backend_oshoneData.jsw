// Initialize the Wix Client for Headless CMS Connection using OAuthStrategy
const wixClient = createClient({
    modules: { items },
    auth: OAuthStrategy({ clientId: WIX_CLIENT_ID })
});

// Jika perlu akses sebagai Admin (contoh: bypass permissions), anda boleh gunakan ApiKeyStrategy:
// const adminClient = createClient({
